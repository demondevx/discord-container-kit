{
  "name": "discord-container-kit",
  "version": "1.0.4",
  "description": "Fluent, type-safe builders for Discord Components V2 - built for discord.js v14",
  "author": "Demondev_",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ bench/",
    "typecheck": "tsc --noEmit",
    "bench": "vitest bench",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "discord.js": "^14.18.0"
  },
  "peerDependenciesMeta": {
    "discord.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "discord.js": "^14.18.0",
    "eslint": "^9.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "undici": "^6.27.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "undici": "^6.27.0"
  },
  "dependencies": {
    "discord-api-types": "^0.37.119"
  },
  "keywords": [
    "discord",
    "discordjs",
    "components",
    "container",
    "builder",
    "discord-ui",
    "v2",
    "discord-components"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/demondevx/discord-container-kit.git"
  },
  "homepage": "https://github.com/demondevx/discord-container-kit#readme",
  "bugs": {
    "url": "https://github.com/demondevx/discord-container-kit/issues"
  }
}
